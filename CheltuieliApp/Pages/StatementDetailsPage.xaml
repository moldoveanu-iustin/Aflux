<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:CheltuieliApp.Converters"
             x:Class="CheltuieliApp.Pages.StatementDetailsPage"
             Title="Detalii extras"
             BackgroundColor="#F5F7FB">

    <ContentPage.Resources>
        <converters:DirectionColorConverter x:Key="DirectionColorConverter" />
    </ContentPage.Resources>

    <Grid>

        <ScrollView>
            <VerticalStackLayout Padding="14" Spacing="10">

                <!-- Header -->
                <HorizontalStackLayout Spacing="10">

                    <Border WidthRequest="36"
                            HeightRequest="36"
                            StrokeThickness="0"
                            BackgroundColor="#EEF2FF"
                            StrokeShape="RoundRectangle 18">

                        <Label Text="‹"
                               FontSize="24"
                               TextColor="#3F51B5"
                               HorizontalTextAlignment="Center"
                               VerticalTextAlignment="Center" />

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnBackTapped" />
                        </Border.GestureRecognizers>
                    </Border>

                    <VerticalStackLayout Spacing="0">
                        <Label Text="Detalii extras"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#111827" />

                        <Label Text="Vezi tranzacțiile asociate acestui extras"
                               FontSize="12"
                               TextColor="#6B7280" />
                    </VerticalStackLayout>

                </HorizontalStackLayout>

                <!-- Import info card -->
                <Border BackgroundColor="White"
                        StrokeThickness="0"
                        Padding="16"
                        StrokeShape="RoundRectangle 26">

                    <VerticalStackLayout Spacing="12">

                        <Grid ColumnDefinitions="Auto,*,Auto"
                              ColumnSpacing="10">

                            <Border WidthRequest="12"
                                    HeightRequest="40"
                                    StrokeThickness="0"
                                    BackgroundColor="{Binding BankColor}"
                                    StrokeShape="RoundRectangle 8" />

                            <VerticalStackLayout Grid.Column="1"
                                                 Spacing="2">
                                <Label Text="{Binding Bank}"
                                       FontSize="18"
                                       FontAttributes="Bold"
                                       TextColor="#111827" />

                                <Label Text="{Binding Period}"
                                       FontSize="13"
                                       TextColor="#6B7280" />
                            </VerticalStackLayout>

                            <Label Grid.Column="2"
                                   Text="{Binding TransactionCountText}"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="#3F51B5"
                                   VerticalTextAlignment="Center" />
                        </Grid>

                        <!--PARTEA DE IBAN-->
                        <!--<Border BackgroundColor="#F8FAFC"
                                StrokeThickness="0"
                                Padding="12"
                                StrokeShape="RoundRectangle 18">

                            <VerticalStackLayout Spacing="4">
                                <Label Text="IBAN"
                                       FontSize="11"
                                       TextColor="#9CA3AF" />

                                <Label Text="{Binding AccountIban}"
                                       FontSize="12"
                                       TextColor="#374151"
                                       LineBreakMode="TailTruncation" />
                            </VerticalStackLayout>
                        </Border>-->

                        <Grid ColumnDefinitions="*,*"
                              ColumnSpacing="10">

                            <Border BackgroundColor="#F0FDF4"
                                    StrokeThickness="0"
                                    Padding="12"
                                    StrokeShape="RoundRectangle 18">

                                <VerticalStackLayout Spacing="2">
                                    <Label Text="Venituri"
                                           FontSize="11"
                                           TextColor="#6B7280" />

                                    <Label Text="{Binding TotalIncomeText}"
                                           FontSize="15"
                                           FontAttributes="Bold"
                                           TextColor="#16A34A" />
                                </VerticalStackLayout>
                            </Border>

                            <Border Grid.Column="1"
                                    BackgroundColor="#FEF2F2"
                                    StrokeThickness="0"
                                    Padding="12"
                                    StrokeShape="RoundRectangle 18">

                                <VerticalStackLayout Spacing="2">
                                    <Label Text="Cheltuieli"
                                           FontSize="11"
                                           TextColor="#6B7280" />

                                    <Label Text="{Binding TotalExpensesText}"
                                           FontSize="15"
                                           FontAttributes="Bold"
                                           TextColor="#DC2626" />
                                </VerticalStackLayout>
                            </Border>

                        </Grid>

                        <Label Text="{Binding ImportedAtText}"
                               FontSize="11"
                               TextColor="#9CA3AF" />

                    </VerticalStackLayout>
                </Border>

                <!-- Actions -->
                <Button Text="Șterge extrasul"
                        HeightRequest="44"
                        CornerRadius="18"
                        BackgroundColor="#FEF2F2"
                        TextColor="#DC2626"
                        FontAttributes="Bold"
                        Clicked="OnDeleteClicked" />

                <!-- Transactions card -->
                <Border BackgroundColor="White"
                        StrokeThickness="0"
                        Padding="14"
                        StrokeShape="RoundRectangle 28">

                    <VerticalStackLayout Spacing="12">

                        <VerticalStackLayout Spacing="2">
                            <Label Text="Tranzacții"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   TextColor="#111827" />

                            <Label Text="Toate tranzacțiile salvate din acest extras"
                                   FontSize="12"
                                   TextColor="#6B7280" />
                        </VerticalStackLayout>

                        <CollectionView ItemsSource="{Binding Transactions}">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border BackgroundColor="#F8FAFC"
                                            StrokeThickness="0"
                                            Padding="12"
                                            Margin="0,0,0,10"
                                            StrokeShape="RoundRectangle 20">

                                        <VerticalStackLayout Spacing="8">

                                            <Grid ColumnDefinitions="*,Auto"
                                                  ColumnSpacing="10">

                                                <VerticalStackLayout Spacing="2">
                                                    <Label Text="{Binding Merchant}"
                                                           FontSize="14"
                                                           FontAttributes="Bold"
                                                           TextColor="#111827"
                                                           LineBreakMode="TailTruncation" />

                                                    <Label Text="{Binding TransactionDate, StringFormat='{0:dd.MM.yyyy}'}"
                                                           FontSize="12"
                                                           TextColor="#6B7280" />
                                                </VerticalStackLayout>

                                                <Label Grid.Column="1"
                                                       Text="{Binding Amount, StringFormat='{0:N2} RON'}"
                                                       TextColor="{Binding Direction, Converter={StaticResource DirectionColorConverter}}"
                                                       FontSize="14"
                                                       FontAttributes="Bold"
                                                       VerticalTextAlignment="Center" />
                                            </Grid>

                                            <Grid ColumnDefinitions="*,Auto"
                                                  ColumnSpacing="10">

                                                <Border BackgroundColor="#EEF2FF"
                                                        StrokeThickness="0"
                                                        Padding="10,5"
                                                        StrokeShape="RoundRectangle 14">

                                                    <Label Text="{Binding CategoryName}"
                                                           FontSize="12"
                                                           TextColor="#3F51B5" />
                                                </Border>

                                                <Label Grid.Column="1"
                                                       Text="{Binding Direction}"
                                                       FontSize="11"
                                                       TextColor="#9CA3AF"
                                                       VerticalTextAlignment="Center" />
                                            </Grid>

                                            <Label Text="{Binding Description}"
                                                   FontSize="11"
                                                   TextColor="#9CA3AF"
                                                   LineBreakMode="TailTruncation" />

                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>