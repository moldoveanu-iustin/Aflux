<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CheltuieliApp.Pages.HelpPage"
             Title="Ajutor"
             BackgroundColor="#F5F7FB">

    <ScrollView>
        <VerticalStackLayout Padding="14" Spacing="12">

            <HorizontalStackLayout Spacing="10">
                <Border WidthRequest="36"
                        HeightRequest="36"
                        StrokeThickness="0"
                        BackgroundColor="#EEF2FF"
                        StrokeShape="RoundRectangle 18">
                    <Label Text="‹"
                           FontSize="24"
                           TextColor="#3F51B5"
                           HorizontalTextAlignment="Center"
                           VerticalTextAlignment="Center" />
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackTapped" />
                    </Border.GestureRecognizers>
                </Border>

                <VerticalStackLayout Spacing="0">
                    <Label Text="Ajutor"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="#111827" />
                    <Label Text="Ghid rapid pentru folosirea aplicației"
                           FontSize="12"
                           TextColor="#6B7280" />
                </VerticalStackLayout>
            </HorizontalStackLayout>

            <Border BackgroundColor="White"
                    StrokeThickness="0"
                    Padding="18"
                    StrokeShape="RoundRectangle 28">
                <VerticalStackLayout Spacing="14">

                    <Label Text="Bănci acceptate"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="#111827" />

                    <Label Text="Aplicația este configurată momentan pentru extrase PDF de la următoarele bănci:"
                           FontSize="14"
                           TextColor="#374151" />

                    <HorizontalStackLayout Spacing="10">
                        <BoxView WidthRequest="14" HeightRequest="14" Color="#38BDF8" VerticalOptions="Center" />
                        <Label Text="Banca Transilvania — BT"
                               FontSize="14"
                               TextColor="#374151" />
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="10">
                        <BoxView WidthRequest="14" HeightRequest="14" Color="#EF4444" VerticalOptions="Center" />
                        <Label Text="BRD"
                               FontSize="14"
                               TextColor="#374151" />
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="10">
                        <BoxView WidthRequest="14" HeightRequest="14" Color="#FACC15" VerticalOptions="Center" />
                        <Label Text="Raiffeisen Bank"
                               FontSize="14"
                               TextColor="#374151" />
                    </HorizontalStackLayout>

                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="White"
                    StrokeThickness="0"
                    Padding="18"
                    StrokeShape="RoundRectangle 28">
                <VerticalStackLayout Spacing="14">

                    <Label Text="Ghid rapid"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="#111827" />

                    <VerticalStackLayout Spacing="10">

                        <Label Text="Acasă"
                               FontSize="15"
                               FontAttributes="Bold"
                               TextColor="#111827" />
                        <Label Text="Aici vezi sumarul lunii selectate, veniturile, cheltuielile și calendarul cu zilele acoperite de extrase. Poți schimba luna cu săgețile."
                               FontSize="13"
                               TextColor="#6B7280" />

                        <BoxView HeightRequest="1" Color="#F3F4F6" />

                        <Label Text="Import"
                               FontSize="15"
                               FontAttributes="Bold"
                               TextColor="#111827" />
                        <Label Text="Aici alegi un extras PDF. Aplicația detectează banca, extrage tranzacțiile și propune categorii. Verifică tranzacțiile, completează categoriile lipsă și apoi confirmă importul."
                               FontSize="13"
                               TextColor="#6B7280" />

                        <BoxView HeightRequest="1" Color="#F3F4F6" />

                        <Label Text="Extrase"
                               FontSize="15"
                               FontAttributes="Bold"
                               TextColor="#111827" />
                        <Label Text="Aici vezi toate extrasele importate. Poți filtra după an și lună, poți deschide un extras pentru detalii sau îl poți șterge împreună cu tranzacțiile asociate."
                               FontSize="13"
                               TextColor="#6B7280" />

                        <BoxView HeightRequest="1" Color="#F3F4F6" />

                        <Label Text="Tranzacții"
                               FontSize="15"
                               FontAttributes="Bold"
                               TextColor="#111827" />
                        <Label Text="Aici poți căuta și filtra toate tranzacțiile după an, lună, tip, categorie sau text. Este zona principală pentru verificarea istoricului complet."
                               FontSize="13"
                               TextColor="#6B7280" />

                        <BoxView HeightRequest="1" Color="#F3F4F6" />

                        <Label Text="Categorii"
                               FontSize="15"
                               FontAttributes="Bold"
                               TextColor="#111827" />
                        <Label Text="Aici poți administra categoriile folosite pentru tranzacții. Categoriile ajută la organizarea și analiza cheltuielilor."
                               FontSize="13"
                               TextColor="#6B7280" />

                        <BoxView HeightRequest="1" Color="#F3F4F6" />

                        <Label Text="Backup"
                               FontSize="15"
                               FontAttributes="Bold"
                               TextColor="#111827" />
                        <Label Text="Aici poți exporta datele aplicației într-un fișier JSON sau poți importa un backup creat anterior."
                               FontSize="13"
                               TextColor="#6B7280" />

                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="#EEF2FF"
                    StrokeThickness="0"
                    Padding="16"
                    StrokeShape="RoundRectangle 24">
                <Label Text="Recomandare: verifică întotdeauna tranzacțiile și categoriile înainte de confirmarea importului."
                       FontSize="13"
                       TextColor="#3F51B5" />
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>