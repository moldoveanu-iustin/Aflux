<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CheltuieliApp.Pages.BackupPage"
             Title="Backup"
             BackgroundColor="#F5F7FB">

    <ScrollView>
        <VerticalStackLayout Padding="14" Spacing="12">

            <HorizontalStackLayout Spacing="10">
                <Border WidthRequest="36"
                        HeightRequest="36"
                        StrokeThickness="0"
                        BackgroundColor="#EEF2FF"
                        StrokeShape="RoundRectangle 18">
                    <Label Text="‹"
                           FontSize="24"
                           TextColor="#3F51B5"
                           HorizontalTextAlignment="Center"
                           VerticalTextAlignment="Center" />
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackTapped" />
                    </Border.GestureRecognizers>
                </Border>

                <VerticalStackLayout Spacing="0">
                    <Label Text="Backup și restaurare"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="#111827" />
                    <Label Text="Exportă sau importă datele aplicației"
                           FontSize="12"
                           TextColor="#6B7280" />
                </VerticalStackLayout>
            </HorizontalStackLayout>

            <Border BackgroundColor="White"
                    StrokeThickness="0"
                    Padding="18"
                    StrokeShape="RoundRectangle 28">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Export backup"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="#111827" />
                    <Label Text="Creează un fișier JSON cu extrasele, tranzacțiile, categoriile și regulile tale."
                           FontSize="14"
                           TextColor="#374151" />
                    <Button Text="Exportă datele"
                            HeightRequest="46"
                            CornerRadius="18"
                            BackgroundColor="#3F51B5"
                            TextColor="White"
                            FontAttributes="Bold"
                            Clicked="OnExportClicked" />
                </VerticalStackLayout>
            </Border>

            <Border BackgroundColor="White"
                    StrokeThickness="0"
                    Padding="18"
                    StrokeShape="RoundRectangle 28">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Import backup"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="#111827" />
                    <Label Text="Alege un fișier JSON exportat anterior. Poți înlocui datele existente sau le poți adăuga peste cele actuale."
                           FontSize="14"
                           TextColor="#374151" />
                    <Button Text="Importă backup"
                            HeightRequest="46"
                            CornerRadius="18"
                            BackgroundColor="#16A34A"
                            TextColor="White"
                            FontAttributes="Bold"
                            Clicked="OnImportClicked" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>