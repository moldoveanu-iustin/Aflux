<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CheltuieliApp.Pages.StatementsPage"
             Title="Extrase"
             BackgroundColor="#F5F7FB">

    <Grid>

        <ScrollView>
            <VerticalStackLayout Padding="14" Spacing="10">

                <!-- Header -->
                <VerticalStackLayout Spacing="0">
                    <Label Text="Extrase importate"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="#111827" />

                    <Label Text="Vezi perioadele importate și extrasele salvate"
                           FontSize="12"
                           TextColor="#6B7280" />
                </VerticalStackLayout>

                <!-- Filters card -->
                <Border BackgroundColor="White"
                        StrokeThickness="0"
                        Padding="14"
                        StrokeShape="RoundRectangle 24">

                    <VerticalStackLayout Spacing="10">

                        <Label Text="Filtre"
                               FontSize="15"
                               FontAttributes="Bold"
                               TextColor="#111827" />

                        <Grid ColumnDefinitions="*,*"
                         ColumnSpacing="10">

                            <!-- YEAR -->
                            <Border BackgroundColor="#F8FAFC"
                            StrokeThickness="0"
                            Padding="12,8"
                            StrokeShape="RoundRectangle 16">

                                <Grid ColumnDefinitions="*,Auto">
                                    <Label x:Name="SelectedYearLabel"
                                       Text="Toți anii"
                                       FontSize="13"
                                       TextColor="#111827"
                                       VerticalTextAlignment="Center" />

                                    <Label Grid.Column="1"
                                   Text="⌄"
                                   FontSize="16"
                                   TextColor="#6B7280"
                                   VerticalTextAlignment="Center" />
                                </Grid>

                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnYearTapped" />
                                </Border.GestureRecognizers>
                            </Border>

                            <!-- MONTH -->
                            <Border Grid.Column="1"
                            BackgroundColor="#F8FAFC"
                            StrokeThickness="0"
                            Padding="12,8"
                            StrokeShape="RoundRectangle 16">

                                <Grid ColumnDefinitions="*,Auto">
                                    <Label x:Name="SelectedMonthLabel"
                                   Text="Toate lunile"
                                   FontSize="13"
                                   TextColor="#111827"
                                   VerticalTextAlignment="Center" />

                                    <Label Grid.Column="1"
                                   Text="⌄"
                                   FontSize="16"
                                   TextColor="#6B7280"
                                   VerticalTextAlignment="Center" />
                                </Grid>

                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnMonthTapped" />
                                </Border.GestureRecognizers>
                            </Border>

                        </Grid>

                    </VerticalStackLayout>
                </Border>

                <!-- Summary card -->
                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="10">

                    <Border BackgroundColor="#EEF2FF"
                            StrokeThickness="0"
                            Padding="14"
                            StrokeShape="RoundRectangle 22">

                        <HorizontalStackLayout Spacing="6">
                            <Label Text="Extrase:"
                           FontSize="12"
                           TextColor="#6B7280" />

                            <Label x:Name="FilteredImportsCountLabel"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="#111827" />
                        </HorizontalStackLayout>
                    </Border>

                    <Border Grid.Column="1"
                            BackgroundColor="#F0FDF4"
                            StrokeThickness="0"
                            Padding="14"
                            StrokeShape="RoundRectangle 22">

                        <HorizontalStackLayout Spacing="6">
                            <Label Text="Tranzacții:"
                           FontSize="12"
                           TextColor="#6B7280" />

                            <Label x:Name="FilteredTransactionsCountLabel"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="#111827" />
                        </HorizontalStackLayout>
                    </Border>

                </Grid>

                <!-- List card -->
                <Border BackgroundColor="White"
                        StrokeThickness="0"
                        Padding="14"
                        StrokeShape="RoundRectangle 28">

                    <VerticalStackLayout Spacing="12">

                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="Lista extraselor"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="#111827" />

                                <Label Text="Apasă pe un extras pentru a vedea tranzacțiile"
                                       FontSize="12"
                                       TextColor="#6B7280" />
                            </VerticalStackLayout>
                        </Grid>

                        <Label x:Name="LoadingStatementsLabel"
                               Text="Se încarcă extrasele..."
                               FontSize="13"
                               TextColor="#6B7280"
                               IsVisible="False" />

                        <CollectionView x:Name="ImportsList"
                                        SelectionMode="Single"
                                        SelectionChanged="OnImportSelected">

                            <CollectionView.EmptyView>
                                <VerticalStackLayout Padding="24"
                                                     Spacing="8"
                                                     HorizontalOptions="Center"
                                                     VerticalOptions="Center">

                                    <Label Text="Nu există extrase importate."
                                           FontSize="14"
                                           FontAttributes="Bold"
                                           TextColor="#111827"
                                           HorizontalTextAlignment="Center" />

                                    <Label Text="Importă primul extras pentru a-l vedea aici."
                                           FontSize="12"
                                           TextColor="#6B7280"
                                           HorizontalTextAlignment="Center" />
                                </VerticalStackLayout>
                            </CollectionView.EmptyView>

                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border BackgroundColor="#F8FAFC"
                                            StrokeThickness="0"
                                            Padding="12"
                                            Margin="0,0,0,10"
                                            StrokeShape="RoundRectangle 20">

                                        <VerticalStackLayout Spacing="10">

                                            <Grid ColumnDefinitions="Auto,*,Auto"
                                                  ColumnSpacing="10">

                                                <Border WidthRequest="12"
                                                        HeightRequest="36"
                                                        StrokeThickness="0"
                                                        BackgroundColor="{Binding BankColor}"
                                                        StrokeShape="RoundRectangle 8" />

                                                <VerticalStackLayout Grid.Column="1"
                                                                     Spacing="2">

                                                    <Label Text="{Binding Bank}"
                                                           FontSize="15"
                                                           FontAttributes="Bold"
                                                           TextColor="#111827" />

                                                    <Label Text="{Binding PeriodText}"
                                                           FontSize="12"
                                                           TextColor="#6B7280" />
                                                </VerticalStackLayout>

                                                <Label Grid.Column="2"
                                                       Text="›"
                                                       FontSize="24"
                                                       TextColor="#9CA3AF"
                                                       VerticalTextAlignment="Center" />
                                            </Grid>

                                            <Grid ColumnDefinitions="*,*"
                                                  ColumnSpacing="10">

                                                <Border BackgroundColor="White"
                                                        StrokeThickness="0"
                                                        Padding="10,6"
                                                        StrokeShape="RoundRectangle 14">

                                                    <Label Text="{Binding TransactionCountText}"
                                                           FontSize="12"
                                                           TextColor="#374151" />
                                                </Border>

                                                <Border Grid.Column="1"
                                                        BackgroundColor="White"
                                                        StrokeThickness="0"
                                                        Padding="10,6"
                                                        StrokeShape="RoundRectangle 14">

                                                    <Label Text="{Binding ImportedAtText}"
                                                           FontSize="12"
                                                           TextColor="#374151" />
                                                </Border>
                                            </Grid>

                                            <!--<Label Text="{Binding AccountIban}"
                                                   FontSize="11"
                                                   TextColor="#9CA3AF"
                                                   LineBreakMode="TailTruncation" />-->

                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!--overlay pentru filtre-->
        <Grid x:Name="FilterOverlay"
      IsVisible="False"
      BackgroundColor="#80000000">

            <Border x:Name="FilterBottomSheet"
            BackgroundColor="White"
            StrokeThickness="0"
            StrokeShape="RoundRectangle 28,28,0,0"
            Padding="20"
            VerticalOptions="End"
            HeightRequest="430">

                <Grid RowDefinitions="Auto,*"
              RowSpacing="12">

                    <Grid Grid.Row="0"
                  ColumnDefinitions="*,Auto">

                        <Label x:Name="FilterTitleLabel"
                       Text="Selectează"
                       FontSize="20"
                       FontAttributes="Bold"
                       TextColor="#111827"
                       VerticalTextAlignment="Center" />

                        <Button Grid.Column="1"
                        Text="×"
                        WidthRequest="40"
                        HeightRequest="40"
                        CornerRadius="20"
                        BackgroundColor="#F3F4F6"
                        TextColor="#111827"
                        Clicked="OnCloseFilterClicked" />
                    </Grid>

                    <CollectionView Grid.Row="1"
                            x:Name="FilterList"
                            SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12"
                                Margin="0,0,0,8"
                                BackgroundColor="#F8FAFC"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 16">

                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnFilterSelected" />
                                    </Border.GestureRecognizers>

                                    <Label Text="{Binding Name}"
                                   FontSize="14"
                                   TextColor="#111827" />
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </Grid>
            </Border>
        </Grid>


        <!--overlay pentru loading extras-->
        <Grid x:Name="OpenStatementLoadingOverlay"
IsVisible="False"
BackgroundColor="#66000000">

            <Border BackgroundColor="White"
      StrokeThickness="0"
      Padding="20"
      StrokeShape="RoundRectangle 24"
      HorizontalOptions="Center"
      VerticalOptions="Center">

                <VerticalStackLayout Spacing="12"
                       HorizontalOptions="Center">

                    <ActivityIndicator IsRunning="True"
                         Color="#3F51B5"
                         WidthRequest="36"
                         HeightRequest="36" />

                    <Label Text="Se deschide extrasul..."
             FontSize="14"
             FontAttributes="Bold"
             TextColor="#111827"
             HorizontalTextAlignment="Center" />

                    <Label Text="Încărcăm tranzacțiile asociate."
             FontSize="12"
             TextColor="#6B7280"
             HorizontalTextAlignment="Center" />

                </VerticalStackLayout>
            </Border>
        </Grid>

    </Grid>
</ContentPage>